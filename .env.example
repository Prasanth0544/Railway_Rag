# ─────────────────────────────────────────────────────────────
# Railway RAG Assistant — Environment Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── LLM Provider ──────────────────────────────────────────────
# Set to "gemini" (cloud) or "lmstudio" (local, free, offline)
LLM_PROVIDER=gemini

# ── Google Gemini API (used when LLM_PROVIDER=gemini) ─────────
GOOGLE_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ── LM Studio Local Server (used when LLM_PROVIDER=lmstudio) ──
# Start LM Studio → Load a model → Enable Local Server
LOCAL_API_BASE=http://localhost:1234/v1
LOCAL_MODEL_NAME=google/gemma-2-9b

# ── Embeddings ────────────────────────────────────────────────
# Set USE_LOCAL_EMBEDDINGS=true to use sentence-transformers offline
# (requires: pip install sentence-transformers)
USE_LOCAL_EMBEDDINGS=true

# ── Data Collections Path ─────────────────────────────────────
# Where your 12k train CSVs live (train_info.csv, station_info.csv, etc.)
DATA_COLLECTIONS_DIR=/path/to/your/data_collections

# Prevent HuggingFace from making network calls (uses cached model)
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
